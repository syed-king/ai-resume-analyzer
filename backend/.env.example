# Database URL — SQLite for local dev, Supabase PostgreSQL for production
DATABASE_URL=sqlite:///./resume.db
# DATABASE_URL=postgresql://user:password@host:5432/dbname   <-- Supabase

# JWT secret — change this to a long random string in production
SECRET_KEY=super-secret-key-change-me-in-production

# Your deployed Vercel frontend URL (update after deploying)
FRONTEND_URL=http://localhost:3000

# HuggingFace API token (optional — increases rate limits on free tier)
# Get one free at https://huggingface.co/settings/tokens
HF_API_TOKEN=

# Set to "true" only if your server has enough RAM (512MB+) for local model
USE_LOCAL_MODEL=false
